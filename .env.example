# EmlakBot ortam değişkenleri örneği. Bu dosyayı .env olarak kopyalayıp doldurun.

# Oturum şifreleme anahtarı (mutlaka değiştirin, rastgele 64+ karakter)
SESSION_SECRET=change-me-to-a-long-random-string

# OpenRouter API (ücretsiz LLM modelleri için)
OPENROUTER_API_KEY=your_openrouter_api_key

# WhatsApp webhook doğrulama tokeni (Meta paneline aynısını gireceksiniz)
VERIFY_TOKEN=gayri_menkul

# (Opsiyonel) Global WhatsApp token — tenant kendi tokenını girmezse fallback
WHATSAPP_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id

# (Opsiyonel) Supabase yedeği — boş bırakılırsa atlanır
SUPABASE_URL=
SUPABASE_KEY=
